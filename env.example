# Backend Environment Variables
# Core API Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_key
GOOGLE_AI_API_KEY=your_google_ai_api_key

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://api.docsflow.app/api/auth/google/callback
GOOGLE_REFRESH_TOKEN=your_google_refresh_token

# CORS Configuration (for production)
ALLOWED_ORIGINS=https://docsflow.app,https://www.docsflow.app,https://*.vercel.app

# Frontend Integration
FRONTEND_URL=https://docsflow.app

# Root Domain Configuration
NEXT_PUBLIC_ROOT_DOMAIN=docsflow.app

# Redis Configuration (optional)
KV_REST_API_URL=your_redis_url
KV_REST_API_TOKEN=your_redis_token

# Environment
NODE_ENV=production 