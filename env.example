# SME Data Intelligence Platform - Environment Variables

# Multi-tenant routing
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000

# Supabase (Database & Auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Google AI (Gemini) - Primary LLM Provider (per ADR Decision 1)
GOOGLE_AI_API_KEY=your-google-ai-api-key

# Redis (Tenant Metadata Storage)
KV_REST_API_URL=your-upstash-redis-url
KV_REST_API_TOKEN=your-upstash-redis-token

# Optional: Pinecone (Vector Database) - Will migrate to Supabase pgvector later
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=sme-intelligence-vectors

# Optional: Authentication (if using NextAuth.js)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret

# Optional: File Storage (if using external storage)
# Currently using Supabase Storage as per ADR Decision 4

# Optional: Email (for notifications)
RESEND_API_KEY=your-resend-api-key

# Optional: Monitoring & Analytics
LOG_LEVEL=info
WEBHOOK_SECRET=your-webhook-secret

# Development Settings
NODE_ENV=development 