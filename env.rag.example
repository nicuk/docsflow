# RAG Enhancement Feature Flags
# Copy these settings to your .env.local file

# ============================================
# PHASE 1: Multimodal Document Parsing
# ============================================

# Enable multimodal parsing (set to true to activate)
FF_MULTIMODAL_PARSING=false

# Comma-separated list of tenant IDs to enable for (leave empty for percentage-based rollout)
FF_MULTIMODAL_TENANTS=demo-tenant,test-company

# Percentage of tenants to enable for (0-100, ignored if tenants list is provided)
FF_MULTIMODAL_PCT=0

# ============================================
# PHASE 2: Knowledge Graph
# ============================================

# Enable knowledge graph construction and hybrid search
FF_KG=false

# Tenant whitelist for knowledge graph
FF_KG_TENANTS=demo-tenant

# Percentage rollout for knowledge graph
FF_KG_PCT=0

# ============================================
# PHASE 3: Vision-Language Model Queries
# ============================================

# Enable VLM for multimodal queries
FF_VLM=false

# Tenant whitelist for VLM
FF_VLM_TENANTS=

# Percentage rollout for VLM
FF_VLM_PCT=0

# ============================================
# PHASE 4: Batch Processing
# ============================================

# Enable batch document processing
FF_BATCH=false

# Tenant whitelist for batch processing
FF_BATCH_TENANTS=

# Percentage rollout for batch processing
FF_BATCH_PCT=0

# ============================================
# Monitoring Configuration
# ============================================

# Alert thresholds
RAG_PARSE_TIMEOUT_MS=5000
RAG_SEARCH_TIMEOUT_MS=1000
RAG_ERROR_RATE_THRESHOLD=10
RAG_FALLBACK_RATE_THRESHOLD=20

# Monitoring endpoint (optional, for external systems)
RAG_METRICS_ENDPOINT=

# ============================================
# Rollout Strategy Examples
# ============================================

# Example 1: Test with specific tenants only
# FF_MULTIMODAL_PARSING=true
# FF_MULTIMODAL_TENANTS=demo-tenant,test-company
# FF_MULTIMODAL_PCT=0

# Example 2: 10% gradual rollout
# FF_MULTIMODAL_PARSING=true
# FF_MULTIMODAL_TENANTS=
# FF_MULTIMODAL_PCT=10

# Example 3: Full production rollout
# FF_MULTIMODAL_PARSING=true
# FF_MULTIMODAL_TENANTS=
# FF_MULTIMODAL_PCT=100
